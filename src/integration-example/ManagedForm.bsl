////////////////////////////////////////////////////////////////////////////////
// Модуль управляемой формы
//
// Назначение:
//   пример загрузки данных из внешней системы и формирования документов.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    Период = ИнтеграцияВнешнейСистемыСервер.ПериодПоУмолчанию();
    ДатаНачала = Период.ДатаНачала;
    ДатаОкончания = Период.ДатаОкончания;

    ПрименитьНастройкиФормы(
        ИнтеграцияВнешнейСистемыСервер.НастройкиПользователя());

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(
    Отказ,
    ЗавершениеРаботы,
    ТекстПредупреждения,
    СтандартнаяОбработка)

    Если ЗавершениеРаботы Тогда
        Возврат;
    КонецЕсли;

    Попытка
        СохранитьНастройкиФормыНаСервере();
    Исключение
        Сообщить(
            "Не удалось сохранить настройки при закрытии формы: "
            + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии()

    // Логика сохранения настроек вынесена в ПередЗакрытием.

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьДанные(Команда)

    ОчиститьСообщения();

    Если НЕ ПроверитьНастройкиПередЗагрузкой() Тогда
        Возврат;
    КонецЕсли;

    Состояние("Загрузка данных из внешней системы...");

    Результат = РезультатЗагрузкиНаСервере();

    Если Результат.Ошибка Тогда
        ПоказатьПредупреждение(, Результат.ТекстОшибки);
        Возврат;
    КонецЕсли;

    Состояние("Загружено записей: " + Результат.КоличествоЗаписей);

КонецПроцедуры

&НаКлиенте
Процедура СформироватьДокументы(Команда)

    ОчиститьСообщения();

    Если ТаблицаДанных.Количество() = 0 Тогда
        ПоказатьПредупреждение(
            ,
            "Нет данных для формирования документов. "
            + "Сначала выполните загрузку.");
        Возврат;
    КонецЕсли;

    Если НЕ ПроверитьНастройкиПередФормированием() Тогда
        Возврат;
    КонецЕсли;

    Состояние("Формирование документов...");

    Результат = РезультатФормированияНаСервере();

    Если Результат.Ошибка Тогда
        ПоказатьПредупреждение(, Результат.ТекстОшибки);
        Возврат;
    КонецЕсли;

    ПоказатьПредупреждение(
        ,
        "Документы успешно сформированы: "
        + Результат.КоличествоДокументов
        + " шт.");

КонецПроцедуры

&НаКлиенте
Процедура КомандаСохранитьНастройки(Команда)

    СохранитьНастройкиФормыНаСервере();
    ПоказатьОповещениеПользователя("Настройки сохранены");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйКодКлиент

&НаКлиенте
Функция ПроверитьНастройкиПередЗагрузкой()

    Если НЕ ЗначениеЗаполнено(АдресСервера) Тогда
        ПоказатьПредупреждение(, "Не указан адрес сервера.");
        Возврат Ложь;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(Токен) Тогда
        ПоказатьПредупреждение(, "Не указан токен авторизации.");
        Возврат Ложь;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(ДатаНачала) Тогда
        ПоказатьПредупреждение(, "Не указана дата начала периода.");
        Возврат Ложь;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(ДатаОкончания) Тогда
        ПоказатьПредупреждение(, "Не указана дата окончания периода.");
        Возврат Ложь;
    КонецЕсли;

    Если НЕ ЭтоДопустимыйПериодЗагрузки() Тогда
        ПоказатьПредупреждение(
            ,
            "Нельзя загружать данные за текущий день.");
        Возврат Ложь;
    КонецЕсли;

    Возврат Истина;

КонецФункции

&НаКлиенте
Функция ПроверитьНастройкиПередФормированием()

    Если НЕ ЗначениеЗаполнено(Организация) Тогда
        ПоказатьПредупреждение(, "Не указана организация.");
        Возврат Ложь;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(Склад) Тогда
        ПоказатьПредупреждение(, "Не указан склад.");
        Возврат Ложь;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
        ПоказатьПредупреждение(, "Не указана номенклатура.");
        Возврат Ложь;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(СчетКасса) Тогда
        ПоказатьПредупреждение(, "Не указан счет кассы.");
        Возврат Ложь;
    КонецЕсли;

    Возврат Истина;

КонецФункции

#КонецОбласти

#Область СлужебныйКодСервер

&НаСервере
Функция РезультатЗагрузкиНаСервере()

    Возврат ИнтеграцияВнешнейСистемыСервер.РезультатЗагрузкиДанных(
        НастройкиФормы(),
        ТаблицаДанных);

КонецФункции

&НаСервере
Функция РезультатФормированияНаСервере()

    Возврат ИнтеграцияВнешнейСистемыСервер
        .РезультатФормированияДокументов(
            НастройкиФормы(),
            ТаблицаДанных);

КонецФункции

&НаСервере
Процедура СохранитьНастройкиФормыНаСервере()

    ИнтеграцияВнешнейСистемыСервер.СохранитьНастройкиПользователя(
        НастройкиФормы());

КонецПроцедуры

&НаСервере
Функция ЭтоДопустимыйПериодЗагрузки()

    Возврат ИнтеграцияВнешнейСистемыСервер.ЭтоДопустимаяДатаЗагрузки(
        ДатаОкончания);

КонецФункции

&НаСервере
Функция НастройкиФормы()

    Настройки = Новый Структура;
    Настройки.Вставить("АдресСервера", АдресСервера);
    Настройки.Вставить("Токен", Токен);
    Настройки.Вставить("ДатаНачала", ДатаНачала);
    Настройки.Вставить("ДатаОкончания", ДатаОкончания);
    Настройки.Вставить("Организация", Организация);
    Настройки.Вставить("Склад", Склад);
    Настройки.Вставить("Номенклатура", Номенклатура);
    Настройки.Вставить("ВидОплаты", ВидОплаты);
    Настройки.Вставить("СчетКасса", СчетКасса);

    Возврат Настройки;

КонецФункции

&НаСервере
Процедура ПрименитьНастройкиФормы(Настройки)

    Если ТипЗнч(Настройки) <> Тип("Структура") Тогда
        Возврат;
    КонецЕсли;

    Настройки.Свойство("АдресСервера", АдресСервера);
    Настройки.Свойство("Токен", Токен);
    Настройки.Свойство("ДатаНачала", ДатаНачала);
    Настройки.Свойство("ДатаОкончания", ДатаОкончания);
    Настройки.Свойство("Организация", Организация);
    Настройки.Свойство("Склад", Склад);
    Настройки.Свойство("Номенклатура", Номенклатура);
    Настройки.Свойство("ВидОплаты", ВидОплаты);
    Настройки.Свойство("СчетКасса", СчетКасса);

КонецПроцедуры

#КонецОбласти

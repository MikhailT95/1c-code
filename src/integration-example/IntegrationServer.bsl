////////////////////////////////////////////////////////////////////////////////
// Общий модуль ИнтеграцияВнешнейСистемыСервер
//
// Назначение:
//   обезличенный пример загрузки данных из внешней системы и формирования
//   документов по этим данным.
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Возвращает период загрузки по умолчанию.
//
// Возвращаемое значение:
//   Структура:
//   * ДатаНачала - Дата
//   * ДатаОкончания - Дата
Функция ПериодПоУмолчанию() Экспорт

    Результат = Новый Структура;
    Результат.Вставить(
        "ДатаНачала",
        НачалоДня(ТекущаяДатаСеанса() - 86400));
    Результат.Вставить(
        "ДатаОкончания",
        КонецДня(Результат.ДатаНачала));

    Возврат Результат;

КонецФункции

// Возвращает настройки пользователя для формы обработки.
//
// Возвращаемое значение:
//   Структура:
//   * АдресСервера - Строка
//   * Токен - Строка
//   * Организация - Произвольный
//   * Склад - Произвольный
//   * Номенклатура - Произвольный
//   * ВидОплаты - Произвольный
//   * СчетКасса - Произвольный
Функция НастройкиПользователя() Экспорт

    Настройки = ХранилищеОбщихНастроек.Загрузить(
        "ПримерИнтеграции",
        "ОсновныеНастройки");

    Если ТипЗнч(Настройки) <> Тип("Структура") Тогда
        Настройки = Новый Структура;
    КонецЕсли;

    Если НЕ Настройки.Свойство("АдресСервера") Тогда
        Настройки.Вставить("АдресСервера", "");
    КонецЕсли;

    Настройки.Вставить("Токен", ТокенИзБезопасногоХранилища());

    Возврат Настройки;

КонецФункции

// Сохраняет настройки пользователя.
//
// Параметры:
//   НастройкиФормы - Структура
//     Ожидаемые свойства:
//     * АдресСервера - Строка
//     * Токен - Строка
//     * Организация - Произвольный
//     * Склад - Произвольный
//     * Номенклатура - Произвольный
//     * ВидОплаты - Произвольный
//     * СчетКасса - Произвольный
Процедура СохранитьНастройкиПользователя(НастройкиФормы) Экспорт

    ХранимыеНастройки = Новый Структура;
    ХранимыеНастройки.Вставить(
        "АдресСервера",
        ЗначениеНастройки(НастройкиФормы, "АдресСервера"));
    ХранимыеНастройки.Вставить(
        "Организация",
        ЗначениеНастройки(НастройкиФормы, "Организация"));
    ХранимыеНастройки.Вставить(
        "Склад",
        ЗначениеНастройки(НастройкиФормы, "Склад"));
    ХранимыеНастройки.Вставить(
        "Номенклатура",
        ЗначениеНастройки(НастройкиФормы, "Номенклатура"));
    ХранимыеНастройки.Вставить(
        "ВидОплаты",
        ЗначениеНастройки(НастройкиФормы, "ВидОплаты"));
    ХранимыеНастройки.Вставить(
        "СчетКасса",
        ЗначениеНастройки(НастройкиФормы, "СчетКасса"));

    ХранилищеОбщихНастроек.Сохранить(
        "ПримерИнтеграции",
        "ОсновныеНастройки",
        ХранимыеНастройки);

    Если ЗначениеЗаполнено(ЗначениеНастройки(НастройкиФормы, "Токен")) Тогда
        СохранитьТокенВБезопасноеХранилище(
            ЗначениеНастройки(НастройкиФормы, "Токен"));
    КонецЕсли;

КонецПроцедуры

// Возвращает признак допустимой даты загрузки.
//
// Параметры:
//   ДатаПроверки - Дата
//
// Возвращаемое значение:
//   Булево - Истина, если загрузка разрешена.
Функция ЭтоДопустимаяДатаЗагрузки(ДатаПроверки) Экспорт

    Возврат ДатаПроверки < НачалоДня(ТекущаяДатаСеанса());

КонецФункции

// Выполняет обезличенную загрузку данных из REST API внешней системы.
//
// Параметры:
//   ПараметрыЗагрузки - Структура
//     * АдресСервера - Строка
//     * Токен - Строка
//     * ДатаНачала - Дата
//     * ДатаОкончания - Дата
//   ТаблицаДанных - ТаблицаЗначений
//
// Возвращаемое значение:
//   Структура:
//   * Ошибка - Булево
//   * ТекстОшибки - Строка
//   * КоличествоЗаписей - Число
Функция РезультатЗагрузкиДанных(
    ПараметрыЗагрузки,
    ТаблицаДанных) Экспорт

    Результат = НовыйРезультатОперации();

    ТекстОшибки = ТекстОшибкиПараметровЗагрузки(ПараметрыЗагрузки);
    Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
        Результат.Ошибка = Истина;
        Результат.ТекстОшибки = ТекстОшибки;
        Возврат Результат;
    КонецЕсли;

    СохранитьНастройкиПользователя(ПараметрыЗагрузки);
    ТаблицаДанных.Очистить();

    HTTPПараметры = ПараметрыHTTPСоединения(
        ЗначениеНастройки(ПараметрыЗагрузки, "АдресСервера"));

    HTTPСоединение = HTTPСоединениеДляЗагрузки(HTTPПараметры);
    ФорматДаты = "ДФ=yyyy-MM-dd";
    НомерСтраницы = 0;
    ВсегоЗаписей = Неопределено;

    Пока Истина Цикл

        HTTPЗапрос = Новый HTTPЗапрос(
            РесурсЗапросаДанных(
                ПараметрыЗагрузки,
                НомерСтраницы,
                ФорматДаты));
        HTTPЗапрос.Заголовки.Вставить("Accept", "application/json");

        Попытка
            HTTPОтвет = HTTPСоединение.Получить(HTTPЗапрос);
        Исключение
            ТекстОшибки = ОписаниеОшибки();
            ЗарегистрироватьОшибка(
                "ПримерИнтеграции.ОшибкаПодключения",
                ТекстОшибки,
                ЗначениеНастройки(ПараметрыЗагрузки, "АдресСервера"));

            Результат.Ошибка = Истина;
            Результат.ТекстОшибки =
                "Ошибка подключения к API внешней системы: " + ТекстОшибки;
            Возврат Результат;
        КонецПопытки;

        Если HTTPОтвет.КодСостояния = 429 Тогда
            Приостановить(2);
            Продолжить;
        КонецЕсли;

        Если HTTPОтвет.КодСостояния <> 200 Тогда
            Результат.Ошибка = Истина;
            Результат.ТекстОшибки =
                "Сервер вернул код ответа: " + HTTPОтвет.КодСостояния;
            Возврат Результат;
        КонецЕсли;

        ДанныеОтвета = ДанныеJSONИзОтвета(HTTPОтвет);
        Если ДанныеОтвета = Неопределено Тогда
            Результат.Ошибка = Истина;
            Результат.ТекстОшибки =
                "Не удалось разобрать JSON-ответ.";
            Возврат Результат;
        КонецЕсли;

        Если ЭтоОтветСОшибкойAPI(ДанныеОтвета, Результат) Тогда
            Возврат Результат;
        КонецЕсли;

        ВсегоЗаписей = ЗначениеИзJSONОбъекта(ДанныеОтвета, "total");
        Если ВсегоЗаписей <> Неопределено Тогда
            ВсегоЗаписей = ЧислоИзЗначенияJSON(ВсегоЗаписей);
        КонецЕсли;

        КоличествоНаСтранице = ЗаполнитьТаблицуИзОтвета(
            ТаблицаДанных,
            ДанныеОтвета);

        Если КоличествоНаСтранице = 0 Тогда
            Прервать;
        КонецЕсли;

        НомерСтраницы = НомерСтраницы + 1;

        Если ВсегоЗаписей <> Неопределено
            И ТаблицаДанных.Количество() >= ВсегоЗаписей Тогда
            Прервать;
        КонецЕсли;

        Приостановить(1);

    КонецЦикла;

    Результат.КоличествоЗаписей = ТаблицаДанных.Количество();
    Возврат Результат;

КонецФункции

// Формирует документы по загруженным данным.
//
// Параметры:
//   ПараметрыФормирования - Структура
//   ТаблицаДанных - ТаблицаЗначений
//
// Возвращаемое значение:
//   Структура:
//   * Ошибка - Булево
//   * ТекстОшибки - Строка
//   * КоличествоДокументов - Число
Функция РезультатФормированияДокументов(
    ПараметрыФормирования,
    ТаблицаДанных) Экспорт

    Результат = НовыйРезультатОперации();

    ТекстОшибки = ТекстОшибкиПараметровФормирования(ПараметрыФормирования);
    Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
        Результат.Ошибка = Истина;
        Результат.ТекстОшибки = ТекстОшибки;
        Возврат Результат;
    КонецЕсли;

    СохранитьНастройкиПользователя(ПараметрыФормирования);

    ТаблицаДат = ТаблицаДанных.Выгрузить();
    ТаблицаДат.Свернуть("ДатаКвитанции");

    Для Каждого СтрокаДаты Из ТаблицаДат Цикл

        Если НЕ ЗначениеЗаполнено(СтрокаДаты.ДатаКвитанции) Тогда
            Продолжить;
        КонецЕсли;

        НачатьТранзакцию();

        Попытка
            ОбработатьДанныеЗаДень(
                СтрокаДаты.ДатаКвитанции,
                ПараметрыФормирования,
                ТаблицаДанных);
            ЗафиксироватьТранзакцию();
            Результат.КоличествоДокументов =
                Результат.КоличествоДокументов + 1;
        Исключение
            ОтменитьТранзакцию();

            ТекстОшибки = ОписаниеОшибки();
            ЗарегистрироватьОшибка(
                "ПримерИнтеграции.ОшибкаФормированияДокумента",
                ТекстОшибки,
                СтрокаДаты.ДатаКвитанции);

            Результат.Ошибка = Истина;
            Результат.ТекстОшибки =
                "Ошибка формирования документа за "
                + Формат(СтрокаДаты.ДатаКвитанции, "ДЛФ=Д")
                + ": "
                + ТекстОшибки;
            Возврат Результат;
        КонецПопытки;

    КонецЦикла;

    Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныйКод

Функция НовыйРезультатОперации()

    Результат = Новый Структура;
    Результат.Вставить("Ошибка", Ложь);
    Результат.Вставить("ТекстОшибки", "");
    Результат.Вставить("КоличествоЗаписей", 0);
    Результат.Вставить("КоличествоДокументов", 0);

    Возврат Результат;

КонецФункции

Функция ЗначениеНастройки(НастройкиФормы, ИмяСвойства)

    Если ТипЗнч(НастройкиФормы) = Тип("Структура")
        И НастройкиФормы.Свойство(ИмяСвойства) Тогда
        Возврат НастройкиФормы[ИмяСвойства];
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Функция ТекстОшибкиПараметровЗагрузки(ПараметрыЗагрузки)

    Если НЕ ЗначениеЗаполнено(
        ЗначениеНастройки(ПараметрыЗагрузки, "АдресСервера")) Тогда
        Возврат "Не указан адрес сервера.";
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(
        ЗначениеНастройки(ПараметрыЗагрузки, "Токен")) Тогда
        Возврат "Не указан токен авторизации.";
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(
        ЗначениеНастройки(ПараметрыЗагрузки, "ДатаНачала")) Тогда
        Возврат "Не указана дата начала периода.";
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(
        ЗначениеНастройки(ПараметрыЗагрузки, "ДатаОкончания")) Тогда
        Возврат "Не указана дата окончания периода.";
    КонецЕсли;

    Если НЕ ЭтоДопустимаяДатаЗагрузки(
        ЗначениеНастройки(ПараметрыЗагрузки, "ДатаОкончания")) Тогда
        Возврат "Нельзя загружать данные за текущий день.";
    КонецЕсли;

    Возврат "";

КонецФункции

Функция ТекстОшибкиПараметровФормирования(ПараметрыФормирования)

    Если НЕ ЗначениеЗаполнено(
        ЗначениеНастройки(ПараметрыФормирования, "Организация")) Тогда
        Возврат "Не указана организация.";
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(
        ЗначениеНастройки(ПараметрыФормирования, "Склад")) Тогда
        Возврат "Не указан склад.";
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(
        ЗначениеНастройки(ПараметрыФормирования, "Номенклатура")) Тогда
        Возврат "Не указана номенклатура.";
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(
        ЗначениеНастройки(ПараметрыФормирования, "СчетКасса")) Тогда
        Возврат "Не указан счет кассы.";
    КонецЕсли;

    Возврат "";

КонецФункции

Функция ПараметрыHTTPСоединения(АдресСервера)

    НормализованныйАдрес = СокрЛП(АдресСервера);
    ИспользоватьHTTPS = Истина;

    Если Лев(НормализованныйАдрес, 8) = "https://" Тогда
        НормализованныйАдрес = Сред(НормализованныйАдрес, 9);
    ИначеЕсли Лев(НормализованныйАдрес, 7) = "http://" Тогда
        ИспользоватьHTTPS = Ложь;
        НормализованныйАдрес = Сред(НормализованныйАдрес, 8);
    КонецЕсли;

    Если Прав(НормализованныйАдрес, 1) = "/" Тогда
        НормализованныйАдрес = Лев(
            НормализованныйАдрес,
            СтрДлина(НормализованныйАдрес) - 1);
    КонецЕсли;

    Порт = ?(ИспользоватьHTTPS, 443, 80);
    ПозицияДвоеточия = СтрНайти(НормализованныйАдрес, ":");

    Если ПозицияДвоеточия > 0 Тогда
        Порт = Число(Сред(НормализованныйАдрес, ПозицияДвоеточия + 1));
        НормализованныйАдрес = Лев(
            НормализованныйАдрес,
            ПозицияДвоеточия - 1);
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("Сервер", НормализованныйАдрес);
    Результат.Вставить("Порт", Порт);
    Результат.Вставить("ИспользоватьHTTPS", ИспользоватьHTTPS);

    Возврат Результат;

КонецФункции

Функция HTTPСоединениеДляЗагрузки(HTTPПараметры)

    Если HTTPПараметры.ИспользоватьHTTPS Тогда
        Возврат Новый HTTPСоединение(
            HTTPПараметры.Сервер,
            HTTPПараметры.Порт,
            ,
            ,
            ,
            30,
            Новый ЗащищенноеСоединениеOpenSSL());
    КонецЕсли;

    Возврат Новый HTTPСоединение(
        HTTPПараметры.Сервер,
        HTTPПараметры.Порт,
        ,
        ,
        ,
        30);

КонецФункции

Функция РесурсЗапросаДанных(
    ПараметрыЗагрузки,
    НомерСтраницы,
    ФорматДаты)

    Возврат
        "/api/entity/export?"
        + "code=example_entity"
        + "&token="
        + ЗначениеНастройки(ПараметрыЗагрузки, "Токен")
        + "&filter[start_date]="
        + Формат(
            ЗначениеНастройки(ПараметрыЗагрузки, "ДатаНачала"),
            ФорматДаты)
        + "&filter[end_date]="
        + Формат(
            ЗначениеНастройки(ПараметрыЗагрузки, "ДатаОкончания"),
            ФорматДаты)
        + "&filter[type]="
        + КодироватьСтроку(
            "main",
            СпособКодированияСтроки.КодировкаURL)
        + "&page="
        + Формат(НомерСтраницы, "ЧГ=");

КонецФункции

Функция ДанныеJSONИзОтвета(HTTPОтвет)

    Попытка
        Чтение = Новый ЧтениеJSON;
        Чтение.УстановитьСтроку(
            HTTPОтвет.ПолучитьТелоКакСтроку("UTF-8"));
        Результат = ПрочитатьJSON(Чтение, Истина);
        Чтение.Закрыть();
        Возврат Результат;
    Исключение
        ЗарегистрироватьОшибка(
            "ПримерИнтеграции.ОшибкаРазбораJSON",
            ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция ЗначениеИзJSONОбъекта(ОбъектJSON, ИмяСвойства)

    Если ТипЗнч(ОбъектJSON) = Тип("Соответствие") Тогда
        Возврат ОбъектJSON.Получить(ИмяСвойства);
    КонецЕсли;

    Если ТипЗнч(ОбъектJSON) = Тип("Структура")
        И ОбъектJSON.Свойство(ИмяСвойства) Тогда
        Возврат ОбъектJSON[ИмяСвойства];
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Функция ЭтоОтветСОшибкойAPI(ДанныеОтвета, Результат)

    СтатусОтвета = ЗначениеИзJSONОбъекта(ДанныеОтвета, "status");
    Если СтатусОтвета = Неопределено Тогда
        Возврат Ложь;
    КонецЕсли;

    Если СтатусОтвета = Истина Тогда
        Возврат Ложь;
    КонецЕсли;

    ТекстОшибкиAPI = "";
    ОшибкаAPI = ЗначениеИзJSONОбъекта(ДанныеОтвета, "error");
    Если ОшибкаAPI <> Неопределено И ОшибкаAPI <> Null Тогда
        ТекстОшибкиAPI = Строка(ОшибкаAPI);
    КонецЕсли;

    Результат.Ошибка = Истина;
    Результат.ТекстОшибки = "API вернул ошибку: " + ТекстОшибкиAPI;

    Возврат Истина;

КонецФункции

Функция ЗаполнитьТаблицуИзОтвета(ТаблицаДанных, ДанныеОтвета)

    МассивДанных = ЗначениеИзJSONОбъекта(ДанныеОтвета, "data");
    Если МассивДанных = Неопределено
        ИЛИ ТипЗнч(МассивДанных) <> Тип("Массив") Тогда
        Возврат 0;
    КонецЕсли;

    КоличествоЗаписей = 0;

    Для Каждого Элемент Из МассивДанных Цикл
        НоваяСтрока = ТаблицаДанных.Добавить();
        НоваяСтрока.ИдентификаторЗаписи = СтрокаИзJSON(Элемент, "id");
        НоваяСтрока.ИдентификаторДокумента = СтрокаИзJSON(
            Элемент,
            "document_id");
        НоваяСтрока.ДатаДокумента = ДатаИзJSON(Элемент, "document_date");
        НоваяСтрока.Описание = СтрокаИзJSON(Элемент, "title");
        НоваяСтрока.Сумма = СуммаИзJSON(Элемент, "amount");
        НоваяСтрока.БезналичнаяОплата = СуммаИзJSON(
            Элемент,
            "cashless_amount");
        КоличествоЗаписей = КоличествоЗаписей + 1;
    КонецЦикла;

    Возврат КоличествоЗаписей;

КонецФункции

Функция СтрокаИзJSON(Элемент, ИмяСвойства)

    Если ТипЗнч(Элемент) = Тип("Соответствие") Тогда
        ЗначениеПоля = Элемент.Получить(ИмяСвойства);
        Если ЗначениеПоля <> Неопределено И ЗначениеПоля <> Null Тогда
            Возврат Строка(ЗначениеПоля);
        КонецЕсли;
    КонецЕсли;

    Возврат "";

КонецФункции

Функция ДатаИзJSON(Элемент, ИмяСвойства)

    СтрокаДаты = СтрокаИзJSON(Элемент, ИмяСвойства);
    Если ПустаяСтрока(СтрокаДаты) Тогда
        Возврат '00010101';
    КонецЕсли;

    Попытка
        Возврат Дата(СтрЗаменить(Лев(СтрокаДаты, 10), "-", ""));
    Исключение
        Возврат '00010101';
    КонецПопытки;

КонецФункции

Функция СуммаИзJSON(Элемент, ИмяСвойства)

    ЗначениеПоля = СтрокаИзJSON(Элемент, ИмяСвойства);
    Если ПустаяСтрока(ЗначениеПоля) Тогда
        Возврат 0;
    КонецЕсли;

    Возврат ЧислоИзЗначенияJSON(ЗначениеПоля) / 100;

КонецФункции

Функция ЧислоИзЗначенияJSON(ЗначениеJSON)

    Попытка
        Возврат Число(ЗначениеJSON);
    Исключение
        Возврат 0;
    КонецПопытки;

КонецФункции

Процедура ОбработатьДанныеЗаДень(
    ДатаДокумента,
    ПараметрыФормирования,
    ТаблицаДанных)

    СтрокиЗаДень = ТаблицаДанных.НайтиСтроки(
        Новый Структура("ДатаДокумента", ДатаДокумента));
    КомментарийАвтозагрузки =
        "Автозагрузка: " + Формат(ДатаДокумента, "ДФ=dd.MM.yyyy");

    ДокументОбъект = ДокументНазначения(
        ДатаДокумента,
        ЗначениеНастройки(ПараметрыФормирования, "Организация"),
        КомментарийАвтозагрузки);

    ДокументОбъект.Склад = ЗначениеНастройки(
        ПараметрыФормирования,
        "Склад");
    ДокументОбъект.СчетКасса = ЗначениеНастройки(
        ПараметрыФормирования,
        "СчетКасса");
    ДокументОбъект.Комментарий = КомментарийАвтозагрузки;

    ДокументОбъект.Товары.Очистить();
    ДокументОбъект.Оплата.Очистить();

    ВидСтавкиНДС = ВидСтавкиНДСНоменклатуры(
        ЗначениеНастройки(ПараметрыФормирования, "Номенклатура"));

    ОбщаяСуммаБезнал = 0;

    Для Каждого СтрокаДанных Из СтрокиЗаДень Цикл
        НоваяСтрокаТовара = ДокументОбъект.Товары.Добавить();
        НоваяСтрокаТовара.Номенклатура = ЗначениеНастройки(
            ПараметрыФормирования,
            "Номенклатура");
        НоваяСтрокаТовара.Количество = 1;
        НоваяСтрокаТовара.Цена = СтрокаДанных.Сумма;
        НоваяСтрокаТовара.Сумма = СтрокаДанных.Сумма;
        НоваяСтрокаТовара.СтавкаНДС =
            СтавкаНДСИзВидаСтавки(ВидСтавкиНДС);
        НоваяСтрокаТовара.СуммаНДС =
            СуммаНДС(СтрокаДанных.Сумма, ВидСтавкиНДС);

        Если СтрокаДанных.БезналичнаяОплата > 0 Тогда
            ОбщаяСуммаБезнал =
                ОбщаяСуммаБезнал + СтрокаДанных.БезналичнаяОплата;
        КонецЕсли;
    КонецЦикла;

    Если ОбщаяСуммаБезнал > 0
        И ЗначениеЗаполнено(
            ЗначениеНастройки(ПараметрыФормирования, "ВидОплаты")) Тогда
        НоваяСтрокаОплаты = ДокументОбъект.Оплата.Добавить();
        НоваяСтрокаОплаты.ВидОплаты = ЗначениеНастройки(
            ПараметрыФормирования,
            "ВидОплаты");
        НоваяСтрокаОплаты.СуммаОплаты = ОбщаяСуммаБезнал;
    КонецЕсли;

    ДокументОбъект.ДополнительныеСвойства.Вставить(
        "ЗаполнитьСчетаУчетаПередЗаписью",
        Истина);
    ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);

КонецПроцедуры

Функция ДокументНазначения(
    ДатаДокумента,
    Организация,
    КомментарийАвтозагрузки)

    СсылкаДокумента = СуществующийДокумент(
        ДатаДокумента,
        Организация,
        КомментарийАвтозагрузки);

    Если ЗначениеЗаполнено(СсылкаДокумента) Тогда
        Возврат СсылкаДокумента.ПолучитьОбъект();
    КонецЕсли;

    ДокументОбъект = Документы.ЦелевойДокумент.СоздатьДокумент();
    ДокументОбъект.Заполнить(Неопределено);
    ДокументОбъект.Дата = КонецДня(ДатаДокумента);
    ДокументОбъект.Организация = Организация;

    Возврат ДокументОбъект;

КонецФункции

Функция СуществующийДокумент(
    ДатаДокумента,
    Организация,
    КомментарийАвтозагрузки)

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |    ЦелевойДокумент.Ссылка КАК Ссылка,
        |    ЦелевойДокумент.Комментарий КАК Комментарий
        |ИЗ
        |    Документ.ЦелевойДокумент КАК ЦелевойДокумент
        |ГДЕ
        |    ЦелевойДокумент.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
        |    И ЦелевойДокумент.Организация = &Организация
        |    И НЕ ЦелевойДокумент.ПометкаУдаления";

    Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаДокумента));
    Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаДокумента));
    Запрос.УстановитьПараметр("Организация", Организация);

    ВыборкаДокументов = Запрос.Выполнить().Выбрать();
    Пока ВыборкаДокументов.Следующий() Цикл
        Если ВРег(СокрЛП(ВыборкаДокументов.Комментарий))
            = ВРег(СокрЛП(КомментарийАвтозагрузки)) Тогда
            Возврат ВыборкаДокументов.Ссылка;
        КонецЕсли;
    КонецЦикла;

    Возврат Документы.ЦелевойДокумент.ПустаяСсылка();

КонецФункции

Функция ВидСтавкиНДСНоменклатуры(НоменклатураСсылка)

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |    Номенклатура.ВидСтавкиНДС КАК ВидСтавкиНДС
        |ИЗ
        |    Справочник.Номенклатура КАК Номенклатура
        |ГДЕ
        |    Номенклатура.Ссылка = &Номенклатура";

    Запрос.УстановитьПараметр("Номенклатура", НоменклатураСсылка);

    ВыборкаНоменклатуры = Запрос.Выполнить().Выбрать();
    Если ВыборкаНоменклатуры.Следующий()
        И ЗначениеЗаполнено(ВыборкаНоменклатуры.ВидСтавкиНДС) Тогда
        Возврат ВыборкаНоменклатуры.ВидСтавкиНДС;
    КонецЕсли;

    Возврат Перечисления.ВидыСтавокНДС.БезНДС;

КонецФункции

Функция СтавкаНДСИзВидаСтавки(ВидСтавкиНДС)

    Если ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Общая Тогда
        Возврат Перечисления.СтавкиНДС.НДС20;
    КонецЕсли;

    Если ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.ОбщаяРасчетная Тогда
        Возврат Перечисления.СтавкиНДС.НДС20_120;
    КонецЕсли;

    Если ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Пониженная Тогда
        Возврат Перечисления.СтавкиНДС.НДС10;
    КонецЕсли;

    Если ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная Тогда
        Возврат Перечисления.СтавкиНДС.НДС10_110;
    КонецЕсли;

    Если ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Нулевая Тогда
        Возврат Перечисления.СтавкиНДС.НДС0;
    КонецЕсли;

    Возврат Перечисления.СтавкиНДС.БезНДС;

КонецФункции

Функция СуммаНДС(СуммаСНДС, ВидСтавкиНДС)

    Если ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Общая
        ИЛИ ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.ОбщаяРасчетная Тогда
        Возврат Окр(СуммаСНДС * 20 / 120, 2);
    КонецЕсли;

    Если ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Пониженная
        ИЛИ ВидСтавкиНДС
            = Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная Тогда
        Возврат Окр(СуммаСНДС * 10 / 110, 2);
    КонецЕсли;

    Возврат 0;

КонецФункции

Процедура СохранитьТокенВБезопасноеХранилище(Токен)

    Попытка
        УстановитьПривилегированныйРежим(Истина);
        ОбщегоНазначения.ЗаписатьДанныеВБезопасноеХранилище(
            "ПримерИнтеграции",
            Токен,
            "Токен");
        УстановитьПривилегированныйРежим(Ложь);
    Исключение
        УстановитьПривилегированныйРежим(Ложь);
        ЗарегистрироватьОшибка(
            "ПримерИнтеграции.ОшибкаБезопасногоХранилища",
            ОписаниеОшибки());
        ВызватьИсключение;
    КонецПопытки;

КонецПроцедуры

Функция ТокенИзБезопасногоХранилища()

    Попытка
        УстановитьПривилегированныйРежим(Истина);
        Токен = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(
            "ПримерИнтеграции",
            "Токен");
        УстановитьПривилегированныйРежим(Ложь);
    Исключение
        УстановитьПривилегированныйРежим(Ложь);
        ЗарегистрироватьОшибка(
            "ПримерИнтеграции.ОшибкаЧтенияБезопасногоХранилища",
            ОписаниеОшибки());
        Возврат "";
    КонецПопытки;

    Если Токен = Неопределено ИЛИ Токен = Null Тогда
        Возврат "";
    КонецЕсли;

    Возврат Токен;

КонецФункции

Процедура ЗарегистрироватьОшибка(
    ИмяСобытия,
    Комментарий,
    Данные = Неопределено)

    ЗаписьЖурналаРегистрации(
        ИмяСобытия,
        УровеньЖурналаРегистрации.Ошибка,
        ,
        Данные,
        Комментарий);

КонецПроцедуры

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Возвращает период по умолчанию.
//
// Возвращаемое значение:
//   Структура:
//   * ДатаНачала - Дата
//   * ДатаОкончания - Дата
Функция ПериодПоУмолчанию() Экспорт

    Период = Новый Структура;
    Период.Вставить("ДатаНачала", НачалоДня(ТекущаяДатаСеанса()));
    Период.Вставить("ДатаОкончания", КонецДня(ТекущаяДатаСеанса()));

    Возврат Период;

КонецФункции

// Возвращает период отображения в зависимости от режима.
//
// Параметры:
//   РежимОтображения - Строка
//   ПериодФормы - СтандартныйПериод
//   ТекущаяДата - Дата
//
// Возвращаемое значение:
//   Структура:
//   * ДатаНачала - Дата
//   * ДатаОкончания - Дата
Функция ПериодОтображения(
    РежимОтображения,
    ПериодФормы,
    ТекущаяДата) Экспорт

    Результат = Новый Структура;

    Если РежимОтображения = "НаДень" Тогда
        Результат.Вставить("ДатаНачала", НачалоДня(ТекущаяДата));
        Результат.Вставить("ДатаОкончания", КонецДня(ТекущаяДата));
    ИначеЕсли РежимОтображения = "НаНеделю" Тогда
        Результат.Вставить("ДатаНачала", НачалоНедели(ТекущаяДата));
        Результат.Вставить("ДатаОкончания", КонецНедели(ТекущаяДата));
    ИначеЕсли РежимОтображения = "НаМесяц" Тогда
        Результат.Вставить("ДатаНачала", НачалоМесяца(ТекущаяДата));
        Результат.Вставить("ДатаОкончания", КонецМесяца(ТекущаяДата));
    Иначе
        Результат.Вставить("ДатаНачала", НачалоДня(ПериодФормы.ДатаНачала));
        Результат.Вставить("ДатаОкончания", КонецДня(ПериодФормы.ДатаОкончания));
    КонецЕсли;

    Возврат Результат;

КонецФункции

// Возвращает список доступных исполнителей.
//
// Возвращаемое значение:
//   ТаблицаЗначений
Функция СписокИсполнителей() Экспорт

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |    ФизическиеЛица.Ссылка КАК Ссылка
        |ИЗ
        |    Справочник.ФизическиеЛица КАК ФизическиеЛица
        |ГДЕ
        |    ФизическиеЛица.ЭтоГруппа = ЛОЖЬ
        |УПОРЯДОЧИТЬ ПО
        |    ФизическиеЛица.Наименование";

    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

// Возвращает список доступных ответственных.
//
// Возвращаемое значение:
//   ТаблицаЗначений
Функция СписокОтветственных() Экспорт

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |    Пользователи.Ссылка КАК Ссылка
        |ИЗ
        |    Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |    Пользователи.Недействителен = ЛОЖЬ
        |    И Пользователи.Служебный = ЛОЖЬ
        |УПОРЯДОЧИТЬ ПО
        |    Пользователи.Наименование";

    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

// Возвращает элементы для заполнения планировщика.
//
// Параметры:
//   ПараметрыОтображения - Структура
//     * РежимОтображения - Строка
//     * ЗаголовокСтраницы - Строка
//     * СписокИсполнителей - Массив
//     * СписокОтветственных - Массив
//     * Период - СтандартныйПериод
//     * ТекущаяДата - Дата
//
// Возвращаемое значение:
//   ТаблицаЗначений:
//   * Начало - Дата
//   * Конец - Дата
//   * Текст - Строка
//   * Значение - Произвольный
Функция ЭлементыПланировщика(ПараметрыОтображения) Экспорт

    Элементы = ТаблицаЭлементовПланировщика();

    Если ПараметрыОтображения.СписокИсполнителей.Количество() = 0
        ИЛИ ПараметрыОтображения.СписокОтветственных.Количество() = 0 Тогда
        Возврат Элементы;
    КонецЕсли;

    Период = ПериодОтображения(
        ПараметрыОтображения.РежимОтображения,
        ПараметрыОтображения.Период,
        ПараметрыОтображения.ТекущаяДата);

    СостояниеЗадачи = СостояниеИзЗаголовка(
        ПараметрыОтображения.ЗаголовокСтраницы);

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |    ЗадачаОрганайзера.Ссылка КАК Ссылка,
        |    ЗадачаОрганайзера.Исполнитель КАК Исполнитель,
        |    ЗадачаОрганайзера.Ответственный КАК Ответственный,
        |    ЗадачаОрганайзера.Описание КАК Описание,
        |    ЗадачаОрганайзера.Номер КАК Номер,
        |    ЗадачаОрганайзера.Состояние КАК Состояние,
        |    ЗадачаОрганайзера.ПлановаяДата КАК ПлановаяДата,
        |    ЗадачаОрганайзера.ФактическаяДата КАК ФактическаяДата,
        |    ЗадачаОрганайзера.ДатаНапоминания КАК ДатаНапоминания,
        |    ЗадачаОрганайзера.Контрагент КАК Контрагент
        |ИЗ
        |    Документ.ЗадачаОрганайзера КАК ЗадачаОрганайзера
        |ГДЕ
        |    ЗадачаОрганайзера.Ответственный В (&СписокОтветственных)
        |    И ЗадачаОрганайзера.Исполнитель В (&СписокИсполнителей)
        |    И (
        |        ЗадачаОрганайзера.ПлановаяДата МЕЖДУ &ДатаНачала И &ДатаОкончания
        |        ИЛИ ЗадачаОрганайзера.ФактическаяДата МЕЖДУ &ДатаНачала И &ДатаОкончания
        |        ИЛИ ЗадачаОрганайзера.ДатаНапоминания МЕЖДУ &ДатаНачала И &ДатаОкончания
        |    )";

    Если ПараметрыОтображения.ЗаголовокСтраницы = "На согласовании" Тогда
        Запрос.Текст = Запрос.Текст
            + Символы.ПС
            + "|    И ЗадачаОрганайзера.НаСогласовании = ИСТИНА";
    Иначе
        Запрос.Текст = Запрос.Текст
            + Символы.ПС
            + "|    И ЗадачаОрганайзера.Состояние = &Состояние";
    КонецЕсли;

    Запрос.УстановитьПараметр(
        "СписокИсполнителей",
        ПараметрыОтображения.СписокИсполнителей);
    Запрос.УстановитьПараметр(
        "СписокОтветственных",
        ПараметрыОтображения.СписокОтветственных);
    Запрос.УстановитьПараметр("ДатаНачала", Период.ДатаНачала);
    Запрос.УстановитьПараметр("ДатаОкончания", Период.ДатаОкончания);

    Если ПараметрыОтображения.ЗаголовокСтраницы <> "На согласовании" Тогда
        Запрос.УстановитьПараметр("Состояние", СостояниеЗадачи);
    КонецЕсли;

    РезультатЗапроса = Запрос.Выполнить().Выгрузить();
    СмещенияПоДате = Новый Соответствие;

    Для Каждого СтрокаСобытия Из РезультатЗапроса Цикл
        ДатаЭлемента = ДатаЭлементаПланировщика(
            ПараметрыОтображения.ЗаголовокСтраницы,
            СтрокаСобытия);

        Если НЕ ЗначениеЗаполнено(ДатаЭлемента) Тогда
            Продолжить;
        КонецЕсли;

        Интервал = ИнтервалЭлемента(
            ДатаЭлемента,
            ПараметрыОтображения.РежимОтображения,
            ПараметрыОтображения.ЗаголовокСтраницы,
            ПараметрыОтображения.ТекущаяДата,
            СмещенияПоДате);

        НоваяСтрока = Элементы.Добавить();
        НоваяСтрока.Начало = Интервал.Начало;
        НоваяСтрока.Конец = Интервал.Конец;
        НоваяСтрока.Текст = ТекстЭлемента(СтрокаСобытия, ДатаЭлемента);
        НоваяСтрока.Значение = СтрокаСобытия.Ссылка;
    КонецЦикла;

    Возврат Элементы;

КонецФункции

#КонецОбласти

#Область СлужебныйКод

Функция ТаблицаЭлементовПланировщика()

    Таблица = Новый ТаблицаЗначений;
    Таблица.Колонки.Добавить("Начало");
    Таблица.Колонки.Добавить("Конец");
    Таблица.Колонки.Добавить("Текст");
    Таблица.Колонки.Добавить("Значение");

    Возврат Таблица;

КонецФункции

Функция СостояниеИзЗаголовка(ЗаголовокСтраницы)

    Если ЗаголовокСтраницы = "На оценке" Тогда
        Возврат Перечисления.СостоянияЗадач.НаОценке;
    КонецЕсли;

    Если ЗаголовокСтраницы = "В работе" Тогда
        Возврат Перечисления.СостоянияЗадач.ВРаботе;
    КонецЕсли;

    Если ЗаголовокСтраницы = "Просрочено" Тогда
        Возврат Перечисления.СостоянияЗадач.Просрочено;
    КонецЕсли;

    Если ЗаголовокСтраницы = "Выполнено" Тогда
        Возврат Перечисления.СостоянияЗадач.Выполнено;
    КонецЕсли;

    Если ЗаголовокСтраницы = "Отменено" Тогда
        Возврат Перечисления.СостоянияЗадач.Отменено;
    КонецЕсли;

    Возврат Перечисления.СостоянияЗадач.ВРаботе;

КонецФункции

Функция ДатаЭлементаПланировщика(ЗаголовокСтраницы, СтрокаСобытия)

    Если ЗаголовокСтраницы = "На оценке"
        ИЛИ ЗаголовокСтраницы = "В работе"
        ИЛИ ЗаголовокСтраницы = "Просрочено" Тогда
        Возврат ?(
            ЗначениеЗаполнено(СтрокаСобытия.ПлановаяДата),
            СтрокаСобытия.ПлановаяДата,
            СтрокаСобытия.ДатаНапоминания);
    КонецЕсли;

    Если ЗаголовокСтраницы = "На согласовании" Тогда
        Возврат СтрокаСобытия.ДатаНапоминания;
    КонецЕсли;

    Возврат СтрокаСобытия.ФактическаяДата;

КонецФункции

Функция ИнтервалЭлемента(
    ДатаЭлемента,
    РежимОтображения,
    ЗаголовокСтраницы,
    ТекущаяДата,
    СмещенияПоДате)

    КлючДня = НачалоДня(ДатаЭлемента);
    Смещение = 0;

    Если СмещенияПоДате.Получить(КлючДня) <> Неопределено Тогда
        Смещение = СмещенияПоДате[КлючДня];
    КонецЕсли;

    Если РежимОтображения = "НаДень"
        И ЗаголовокСтраницы = "Просрочено" Тогда
        Начало = НачалоДня(ТекущаяДата) + Смещение * 60;
        Конец = КонецМинуты(Начало);
    Иначе
        Начало = НачалоЧаса(ДатаЭлемента + Смещение * 3600);
        Конец = КонецЧаса(Начало);
    КонецЕсли;

    СмещенияПоДате.Вставить(КлючДня, Смещение + 1);

    Интервал = Новый Структура;
    Интервал.Вставить("Начало", Начало);
    Интервал.Вставить("Конец", Конец);

    Возврат Интервал;

КонецФункции

Функция ТекстЭлемента(СтрокаСобытия, ДатаЭлемента)

    ЧастиТекста = Новый Массив;
    ЧастиТекста.Добавить(Строка(СтрокаСобытия.Контрагент));
    ЧастиТекста.Добавить("Номер: " + Строка(СтрокаСобытия.Номер));
    ЧастиТекста.Добавить("Дата: " + Формат(ДатаЭлемента, "ДЛФ=ДТ"));
    ЧастиТекста.Добавить("Состояние: " + Строка(СтрокаСобытия.Состояние));
    ЧастиТекста.Добавить("Исполнитель: " + Строка(СтрокаСобытия.Исполнитель));
    ЧастиТекста.Добавить(Строка(СтрокаСобытия.Описание));

    Возврат СтрСоединить(ЧастиТекста, Символы.ПС);

КонецФункции

#КонецОбласти

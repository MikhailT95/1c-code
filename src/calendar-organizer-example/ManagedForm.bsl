////////////////////////////////////////////////////////////////////////////////
// Модуль управляемой формы
//
// Назначение:
//   демонстрационный календарный органайзер для просмотра задач
//   по статусам, исполнителям и ответственным.
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриОткрытииНаСервере()

    ЗаполнитьТаблицуИсполнителей();
    ЗаполнитьТаблицуОтветственных();

    ЗаполнитьИсполнителей = Истина;
    ЗаполнитьОтветственных = Истина;

    Для Каждого СтрокаИсполнителя Из ЭтотОбъект.ТаблицаИсполнителей Цикл
        СтрокаИсполнителя.Выбран = Истина;
    КонецЦикла;

    Для Каждого СтрокаОтветственного Из ЭтотОбъект.ТаблицаОтветственных Цикл
        СтрокаОтветственного.Выбран = Истина;
    КонецЦикла;

    Период = ОрганайзерКалендаряСервер.ПериодПоУмолчанию();
    ЭтотОбъект.Период.ДатаНачала = Период.ДатаНачала;
    ЭтотОбъект.Период.ДатаОкончания = Период.ДатаОкончания;

    ЭтаФорма.Масштаб = 60;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

    ПриОткрытииНаСервере();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиВыбора

&НаКлиенте
Процедура ЗаполнитьИсполнителейПриИзменении(Элемент)

    Для Каждого СтрокаИсполнителя Из ЭтотОбъект.ТаблицаИсполнителей Цикл
        СтрокаИсполнителя.Выбран = ЗаполнитьИсполнителей;
    КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьОтветственныхПриИзменении(Элемент)

    Для Каждого СтрокаОтветственного Из ЭтотОбъект.ТаблицаОтветственных Цикл
        СтрокаОтветственного.Выбран = ЗаполнитьОтветственных;
    КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура СтатусыЗадачПриСменеСтраницы(Элемент, ТекущаяСтраница)

    Планировщик.Элементы.Очистить();

КонецПроцедуры

&НаКлиенте
Процедура ПланировщикВыбор(Элемент, СтандартнаяОбработка)

    СтандартнаяОбработка = Ложь;

    Если Элемент.ВыделенныеЭлементы.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;

    ПараметрыФормы = Новый Структура(
        "Ключ",
        Элемент.ВыделенныеЭлементы[0].Значение);
    ОткрытьФорму("Документ.ЗадачаОрганайзера.ФормаОбъекта", ПараметрыФормы);

КонецПроцедуры

#КонецОбласти

#Область Команды

&НаКлиенте
Процедура ПоказатьНаДень(Команда)

    ОбновитьПланировщик("НаДень");

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьНаНеделю(Команда)

    ОбновитьПланировщик("НаНеделю");

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьНаМесяц(Команда)

    ОбновитьПланировщик("НаМесяц");

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьПоПериоду(Команда)

    Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Период) Тогда
        Сообщение = Новый СообщениеПользователю;
        Сообщение.Текст = "Не заполнен период.";
        Сообщение.Сообщить();
        Возврат;
    КонецЕсли;

    ОбновитьПланировщик("ПоПериоду");

КонецПроцедуры

#КонецОбласти

#Область СлужебныйКодКлиент

&НаКлиенте
Процедура ОбновитьПланировщик(РежимОтображения)

    ЗаголовокСтраницы =
        ЭтаФорма.Элементы.СтатусыЗадач.ТекущаяСтраница.Заголовок;

    ЗаполнитьПланировщикНаСервере(РежимОтображения, ЗаголовокСтраницы);
    НастроитьПланировщик(РежимОтображения, ЗаголовокСтраницы);

КонецПроцедуры

&НаКлиенте
Процедура НастроитьПланировщик(РежимОтображения, ЗаголовокСтраницы)

    Планировщик.АвтоМинимальнаяВысотаСтроки = Ложь;
    Планировщик.АвтоМинимальнаяШиринаКолонки = Ложь;
    Планировщик.ТекущиеПериодыОтображения.Очистить();
    Планировщик.ФорматПеренесенныхЗаголовковШкалыВремени =
        "ДФ='дддд, д ММММ гггг'";

    Если РежимОтображения = "НаДень"
        И ЗаголовокСтраницы = "Просрочено" Тогда
        Планировщик.МинимальнаяВысотаСтроки = 20;
        Планировщик.МинимальнаяШиринаКолонки = 35;
        Планировщик.ЕдиницаПериодическогоВарианта =
            ТипЕдиницыШкалыВремени.Минута;
        Планировщик.КратностьПериодическогоВарианта = 1;
        Планировщик.ВыравниватьГраницыЭлементовПоШкалеВремени = Ложь;
    Иначе
        Планировщик.МинимальнаяВысотаСтроки = 20;
        Планировщик.МинимальнаяШиринаКолонки = 35;
        Планировщик.ЕдиницаПериодическогоВарианта =
            ТипЕдиницыШкалыВремени.Час;
        Планировщик.КратностьПериодическогоВарианта = 24;
        Планировщик.ВыравниватьГраницыЭлементовПоШкалеВремени = Истина;
    КонецЕсли;

    ПериодОтображения = ОрганайзерКалендаряСервер.ПериодОтображения(
        РежимОтображения,
        ЭтотОбъект.Период,
        ТекущаяДата());

    Планировщик.НачалоПериодаОтображения = ПериодОтображения.ДатаНачала;
    Планировщик.КонецПериодаОтображения = ПериодОтображения.ДатаОкончания;
    Планировщик.ТекущиеПериодыОтображения.Добавить(
        ПериодОтображения.ДатаНачала,
        ПериодОтображения.ДатаОкончания);

КонецПроцедуры

#КонецОбласти

#Область СлужебныйКодСервер

&НаСервере
Процедура ЗаполнитьПланировщикНаСервере(
    РежимОтображения,
    ЗаголовокСтраницы)

    Планировщик.Элементы.Очистить();

    Параметры = Новый Структура;
    Параметры.Вставить("РежимОтображения", РежимОтображения);
    Параметры.Вставить("ЗаголовокСтраницы", ЗаголовокСтраницы);
    Параметры.Вставить(
        "СписокИсполнителей",
        ВыбранныеИсполнители());
    Параметры.Вставить(
        "СписокОтветственных",
        ВыбранныеОтветственные());
    Параметры.Вставить("Период", ЭтотОбъект.Период);
    Параметры.Вставить("ТекущаяДата", ТекущаяДатаСеанса());

    ЭлементыКалендаря =
        ОрганайзерКалендаряСервер.ЭлементыПланировщика(Параметры);

    Для Каждого СтрокаЭлемента Из ЭлементыКалендаря Цикл
        НовыйЭлемент = Планировщик.Элементы.Добавить(
            СтрокаЭлемента.Начало,
            СтрокаЭлемента.Конец);
        НовыйЭлемент.Текст = СтрокаЭлемента.Текст;
        НовыйЭлемент.Значение = СтрокаЭлемента.Значение;
    КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуИсполнителей()

    РезультатЗапроса = ОрганайзерКалендаряСервер.СписокИсполнителей();

    Для Каждого СтрокаДанных Из РезультатЗапроса Цикл
        НоваяСтрока = ЭтотОбъект.ТаблицаИсполнителей.Добавить();
        НоваяСтрока.ФизЛицо = СтрокаДанных.Ссылка;
    КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуОтветственных()

    РезультатЗапроса = ОрганайзерКалендаряСервер.СписокОтветственных();

    Для Каждого СтрокаДанных Из РезультатЗапроса Цикл
        НоваяСтрока = ЭтотОбъект.ТаблицаОтветственных.Добавить();
        НоваяСтрока.Пользователь = СтрокаДанных.Ссылка;
    КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ВыбранныеИсполнители()

    Список = Новый Массив;

    Для Каждого СтрокаИсполнителя Из ЭтотОбъект.ТаблицаИсполнителей Цикл
        Если СтрокаИсполнителя.Выбран Тогда
            Список.Добавить(СтрокаИсполнителя.ФизЛицо);
        КонецЕсли;
    КонецЦикла;

    Возврат Список;

КонецФункции

&НаСервере
Функция ВыбранныеОтветственные()

    Список = Новый Массив;

    Для Каждого СтрокаОтветственного Из ЭтотОбъект.ТаблицаОтветственных Цикл
        Если СтрокаОтветственного.Выбран Тогда
            Список.Добавить(СтрокаОтветственного.Пользователь);
        КонецЕсли;
    КонецЦикла;

    Возврат Список;

КонецФункции

#КонецОбласти
